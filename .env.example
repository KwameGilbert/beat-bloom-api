API_VERSION=v1
APP_NAME=EasyBeats API
BCRYPT_ROUNDS=12
CLOUDINARY_API_KEY=dummy_cloudinary_api_key
CLOUDINARY_API_SECRET=dummy_cloudinary_api_secret
CLOUDINARY_CLOUD_NAME=dummy_cloudinary_cloud
CLOUDINARY_FOLDER=dummy_folder
CORS_ORIGIN=http://localhost:5173
DB_CLIENT=pg
DATABASE_URL=postgresql://dummy_user:dummy_password@localhost:5432/dummy_db
DB_HOST=127.0.0.1
DB_NAME=dummy_db
DB_PASSWORD=dummy_password
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_PORT=5432
DB_USER=dummy_user
EMAIL_PROVIDER=smtp
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=dummy@example.com
EMAIL_PASSWORD=dummy_email_password
EMAIL_FROM="EasyBeats <noreply@example.com>"
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
GOOGLE_CLIENT_ID=dummy_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=dummy_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
HASH_ALGORITHM=bcrypt
HASH_KEY_LENGTH=64
HASH_SALT_LENGTH=16
HOST=127.0.0.1
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
JWT_REFRESH_SECRET=dummy_refresh_secret_at_least_32_chars_long
JWT_SECRET=dummy_jwt_secret_at_least_32_chars_long
LOG_LEVEL=info
NODE_ENV=development

# Payment Configuration ('paystack' or 'hubtel')
PAYMENT_PROVIDER=paystack

# Paystack Integration
PAYSTACK_SECRET_KEY=dummy_paystack_secret_key

# Hubtel Integration
HUBTEL_CLIENT_ID=dummy_hubtel_client_id
HUBTEL_CLIENT_SECRET=dummy_hubtel_client_secret
HUBTEL_MERCHANT_ACCOUNT_NUMBER=dummy_hubtel_merchant_account_number
HUBTEL_CALLBACK_URL=http://localhost:3000/api/payments/webhook
HUBTEL_RETURN_URL=http://localhost:5173/checkout
HUBTEL_CANCELLATION_URL=http://localhost:5173/checkout?status=cancelled

PORT=3000
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000
UPLOAD_LOCAL_PATH=uploads
UPLOAD_MAX_DOCUMENT_SIZE=10485760
UPLOAD_MAX_FILE_SIZE=5242880
UPLOAD_MAX_IMAGE_SIZE=5242880
UPLOAD_MAX_VIDEO_SIZE=52428800
UPLOAD_STRATEGY=cloudinary
